{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "shared/**/*.js",
    "jira_management/**/*.js",
    "git_triggers/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.js",
    "**/__tests__/**"
  ]
}
