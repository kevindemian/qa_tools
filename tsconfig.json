{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "allowJs": false,
    "noEmit": true,
    "strict": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"]
  },
  "include": [
    "shared/**/*.ts",
    "jira_management/**/*.ts",
    "git_triggers/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
