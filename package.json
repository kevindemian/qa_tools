{
    "name": "qa_tools",
    "version": "1.0.0",
    "description": "QA automation tools for Jira/Xray, GitLab, and GitHub",
    "bin": {
        "qa-jira": "./dist/jira_management/main.js",
        "qa-git": "./dist/git_triggers/main.js"
    },
    "main": "jira_management/main.ts",
    "scripts": {
        "setup": "bash setup.sh",
        "test": "NODE_OPTIONS=--max-old-space-size=2048 vitest run",
        "test:coverage": "NODE_OPTIONS=--max-old-space-size=2048 vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "lint": "npx tsx scripts/quality-check.ts",
        "unused-exports": "ts-prune -p tsconfig.json | grep -v \"(used in module)\" || true",
        "format": "prettier --write '**/*.{ts,js,json,md}'",
        "build": "node scripts/build.mjs",
        "docs": "echo 'Documentation generation removed (docs-archive/)'",
        "jira": "npx tsx jira_management/main.ts",
        "git": "npx tsx git_triggers/main.ts",
        "smoke:github": "npx tsx e2e/smoke-github.ts",
        "smoke:llm": "npx tsx e2e/smoke-llm.ts",
        "smoke:pipeline": "E2E_PIPELINE=true npx tsx e2e/smoke-pipeline.ts",
        "smoke": "npx tsx e2e/smoke-github.ts",
        "generate-env-example": "npx tsx scripts/generate-env-example.ts",
        "snyk-test": "snyk test --all-projects --severity-threshold=high --json > snyk-report.json 2>&1 || true",
        "gitleaks": "gitleaks detect --source . --verbose --redact",
        "osv-scan": "osv-scanner --lockfile=package-lock.json --format json > osv-report.json 2>&1 || true",
        "sonar": "npx sonar-scanner",
        "type-coverage": "npx type-coverage --detail --at-least 95",
        "depcruise": "npx depcruise --config .dependency-cruiser.js shared/ jira_management/ git_triggers/ scripts/"
    },
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@inquirer/confirm": "^6.0.13",
        "@inquirer/editor": "^5.2.2",
        "@inquirer/input": "^5.1.2",
        "@inquirer/select": "^5.1.5",
        "adm-zip": "^0.5.17",
        "axios": "^1.18.1",
        "chalk": "^5.6.2",
        "cli-progress": "^3.12.0",
        "cli-table3": "^0.6.5",
        "csv-parser": "^3.2.0",
        "dotenv": "^17.4.2",
        "fast-xml-parser": "^5.9.3",
        "figlet": "^1.11.0",
        "glob": "^13.0.6",
        "gradient-string": "^3.0.0",
        "ora": "^9.4.1",
        "readline-sync": "^1.4.10",
        "yaml": "^2.9.0",
        "zod": "^4.4.3"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.js": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/adm-zip": "^0.5.8",
        "@types/cli-progress": "^3.11.6",
        "@types/node": "^25.9.2",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/eslint-plugin": "^1.6.20",
        "dependency-cruiser": "^18.0.0",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-security": "^4.0.1",
        "eslint-plugin-sonarjs": "^4.1.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "fast-check": "^4.8.0",
        "knip": "^6.23.0",
        "memfs": "^4.57.8",
        "nock": "^14.0.16",
        "prettier": "^3.8.4",
        "ts-prune": "^0.10.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vitest": "^4.1.9"
    }
}
