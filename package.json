{
    "name": "qa_tools",
    "version": "1.0.0",
    "description": "QA automation tools for Jira/Xray, GitLab, and GitHub",
    "bin": {
        "qa-jira": "./dist/jira_management/main.js",
        "qa-git": "./dist/git_triggers/main.js"
    },
    "main": "jira_management/main.ts",
    "scripts": {
        "setup": "bash setup.sh",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext .ts && bash scripts/check-unused-exports.sh && npm run check-handlers",
        "format": "prettier --write '**/*.{ts,js,json,md}'",
        "build": "npx tsc -p tsconfig.build.json && node -e \"require('fs').writeFileSync('dist/jira_management/main.js','#!/usr/bin/env node\\n'+require('fs').readFileSync('dist/jira_management/main.js','utf8'))\" && node -e \"require('fs').writeFileSync('dist/git_triggers/main.js','#!/usr/bin/env node\\n'+require('fs').readFileSync('dist/git_triggers/main.js','utf8'))\"",
        "docs": "echo 'Documentation generation removed (docs-archive/)'",
        "unused-exports": "bash scripts/check-unused-exports.sh",
        "check-handlers": "echo '=== Files → handlers ===' && for f in jira_management/commands/case[0-9][0-9].ts; do id=\"${f##*case}\"; id=\"${id%.ts}\"; id=$(echo $id | sed 's/^0*//'); grep -q \"'${id}':\" jira_management/commands/index.ts && echo \"✅ $(basename $f) → handler '${id}'\" || echo \"❌ $(basename $f) → MISSING\"; done && echo '=== Handlers → files ===' && grep -oP \"'\\K\\d+(?=': \\{ handler:)\" jira_management/commands/index.ts | while IFS= read -r id; do file=\"jira_management/commands/case$(printf '%02d' $id).ts\"; [ -f \"$file\" ] && echo \"✅ handler '${id}' → $(basename $file)\" || echo \"❌ handler '${id}' → MISSING file\"; done",
        "jira": "npx tsx jira_management/main.ts",
        "git": "npx tsx git_triggers/main.ts",
        "quality-gate": "npx tsx scripts/quality-gate.ts",
        "smoke:github": "npx tsx e2e/smoke-github.ts",
        "smoke:llm": "npx tsx e2e/smoke-llm.ts",
        "smoke:pipeline": "E2E_PIPELINE=true npx tsx e2e/smoke-pipeline.ts",
        "smoke": "npx tsx e2e/smoke-github.ts",
        "prepare": "husky"
    },
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@inquirer/confirm": "^6.0.13",
        "@inquirer/input": "^5.0.13",
        "@inquirer/select": "^5.1.5",
        "adm-zip": "^0.5.17",
        "axios": "^1.15.2",
        "chalk": "^4.1.2",
        "cli-progress": "^3.12.0",
        "cli-table3": "^0.6.5",
        "csv-parser": "^3.2.0",
        "dotenv": "^17.4.2",
        "figlet": "^1.11.0",
        "glob": "^10.5.0",
        "glob": "^10.5.0",
        "gradient-string": "^3.0.0",
        "ora": "^9.4.0",
        "readline-sync": "^1.4.10",
        "yaml": "^2.9.0",
        "zod": "^4.4.3"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.js": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@jest/globals": "^30.4.1",
        "@types/adm-zip": "^0.5.8",
        "@types/cli-progress": "^3.11.6",
        "@types/figlet": "^1.7.0",
        "@types/gradient-string": "^1.1.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.1",
        "@types/yaml": "^1.9.6",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.0.5",
        "nock": "^14.0.15",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.11",
        "ts-prune": "^0.10.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4"
    }
}
