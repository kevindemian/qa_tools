#!/bin/sh
set -e

echo "=== Running pre-commit checks (validation hook + typecheck + lint) ==="

# Validation hook test
VALIDATION_HOOK="$HOME/.config/opencode/validation_hook.ts"
if [ -f "$VALIDATION_HOOK" ]; then
    echo "--- Validation hook (self-test) ---"
    npx tsx "$VALIDATION_HOOK" --test

    echo "--- Validation hook (diff check) ---"
    git diff --cached -- . ':!.config/validation_hook.ts' | npx tsx "$VALIDATION_HOOK" --check
fi

echo "--- Typecheck ---"
npx tsc --noEmit

echo "--- Lint-staged ---"
npx lint-staged

echo "--- Checking for .only ---"
! grep -rn '[.]only(' --include='*.test.*' --exclude-dir=node_modules --exclude-dir=.git .

echo "=== Pre-commit checks passed ==="
