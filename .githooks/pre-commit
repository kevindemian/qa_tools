#!/bin/sh
set -e

# Clear stale COMMIT_EDITMSG from previous commit.
# git runs pre-commit BEFORE preparing the commit message, so COMMIT_EDITMSG
# always contains the previous commit's message — never the current one.
rm -f "$(git rev-parse --show-toplevel)/.git/COMMIT_EDITMSG"

echo "=== Running pre-commit checks (validation hook + vigilant + typecheck + lint) ==="

# Validation hook test
VALIDATION_HOOK="$HOME/.config/opencode/validation_hook.ts"
if [ -f "$VALIDATION_HOOK" ]; then
    echo "--- Validation hook (self-test) ---"
    npx tsx "$VALIDATION_HOOK" --test

    echo "--- Validation hook (diff check) ---"
    STAGED_DIFF=$(git diff --cached -- . ':!.config/validation_hook.ts' ':!BACKLOG.md')
    if [ -n "$STAGED_DIFF" ]; then
        echo "$STAGED_DIFF" | grep '^[+]' | sed 's/^.//' | npx tsx "$VALIDATION_HOOK" --check --no-cache
    else
        echo "  (no staged changes to validate)"
    fi
fi

echo "--- Rule-vigilant scan (security configs) ---"
VIGILANT="scripts/rule-vigilant.ts"
if [ -f "$VIGILANT" ]; then
    for f in eslint.config.mjs .dependency-cruiser.js .gitleaks.toml AGENTS.md scripts/quality-check.ts; do
        if [ -f "$f" ]; then
            npx tsx "$VIGILANT" --file "$f" --quiet || echo "  [vigilant] warnings em $f"
        fi
    done
fi

echo "--- Typecheck ---"
npx tsc --noEmit

echo "--- Lint-staged ---"
npx lint-staged

echo "--- Checking for .only ---"
! grep -rn '[.]only(' --include='*.test.*' --exclude-dir=node_modules --exclude-dir=.git .

echo "=== Pre-commit checks passed ==="
