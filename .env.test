# ═══════════════════════════════════════════════════════════════
# QA Tools — HERMETIC TEST SANDBOX
# Loaded INSTEAD of .env.local when running tests (vitest / NODE_ENV=test).
# Contains ONLY fake localhost/nock URLs and dummy tokens so automated
# tests never touch the real Jira/Xray/GitLab production environment.
# Safe to commit (no real secrets).
#
# IMPORTANT: this file is a CONNECTION/IDENTITY sandbox only. It must NOT
# set behavior/display/QA-gate/CI/Live-token vars (QUIET, NO_COLOR,
# AUTO_CHOICE, AUTO_CONFIRM, ON_ERROR, DRY_RUN, QA_GATE_*, GITHUB_TOKEN,
# CI, LOG_*, ...). Those are asserted as "unset"/default by many unit
# tests (prompt, config, cli, github-pr-comment, ...) and would pollute
# the global test environment. e2e tests that need a behavior flag set it
# explicitly in their own beforeAll/beforeEach (see e2e/*.test.ts).
# ═══════════════════════════════════════════════════════════════

# ── Jira / Xray (sandbox: matched by nock in e2e tests) ──────
JIRA_BASE_URL=http://localhost:1999/jira
JIRA_PERSONAL_TOKEN=test-jira-token
JIRA_USER_EMAIL=test@example.com
JIRA_MODE=cloud
XRAY_BASE_URL=http://localhost:1999/xray
XRAY_MODE=server
XRAY_CLIENT_ID=test-xray-client-id
XRAY_CLIENT_SECRET=test-xray-client-secret
XRAY_CLOUD_URL=http://localhost:1999/xray
JIRA_PROJECT=ECSPOL

# ── Git (GitLab) — sandbox only; live GitHub/GitLab tokens are intentionally
#     NOT set here so live e2e suites (skipIf(!token)) stay skipped in CI. ──
GIT_TOKEN=test-git-token
GIT_BASE_URL=http://localhost:9998/api/v4

# ── CSV / JSON Import ───────────────────────────────────────
# CSV_PATH / JSON_PATH / CSV_LABELS / JSON_LABELS are intentionally LEFT
# EMPTY in the sandbox. resolveCsvPath/resolveJsonPath fall back to a prompted
# path (mocked in tests); setting them to a real value would hijack the prompt
# path (or the label) and break import tests that rely on the mocked input
# (e.g. integration-handlers.test.ts asserts the prompted label, not a config one).
CSV_DEFAULT_PATH=
CSV_PATH=
CSV_LABELS=
JSON_PATH=
JSON_LABELS=

# ── Local state / IO dirs (redirected to /tmp so tests stay hermetic) ──
QA_TOOLS_LOGS_DIR=/tmp/qa-tools-logs
QA_TOOLS_TEMP_DIR=/tmp/qa-tools-temp
QA_TOOLS_REPORTS_DIR=/tmp/qa-tools-reports
XDG_STATE_HOME=/tmp/qa-tools-state
LLM_DISK_CACHE_DIR=/tmp/qa-tools-llm-cache

# ── LLM Providers (dummy connection config; tests mock or skip real calls) ─
LLM_PROVIDER=
LLM_API_KEY=test-llm-key
LLM_MODEL=test-model
LLM_BASE_URL=http://localhost:9977/v1
LLM_FAST_API_KEY=test-fast-key
LLM_FAST_MODEL=test-fast-model
LLM_FAST_BASE_URL=http://localhost:9977/v1
LLM_REVIEW_API_KEY=test-review-key
LLM_REVIEW_MODEL=test-review-model
LLM_REVIEW_BASE_URL=http://localhost:9977/v1
LLM_FALLBACK_API_KEY=test-fallback-key
LLM_FALLBACK_MODEL=test-fallback-model
LLM_FALLBACK_BASE_URL=http://localhost:9977/v1
LLM_BATCH_API_KEY=test-batch-key
LLM_BATCH_MODEL=test-batch-model
LLM_BATCH_BASE_URL=http://localhost:9977/v1
