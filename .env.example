# === Jira Configuration ===
# URL base do servidor Jira (obrigatório)
JIRA_BASE_URL=https://seu-jira-server
# Token pessoal para autenticação Jira (obrigatório)
JIRA_PERSONAL_TOKEN=seu-token-aqui
# URL base do Xray (obrigatório para criar testes com steps/pre-conditions)
XRAY_BASE_URL=https://seu-xray-server

# === GitLab Configuration ===
# URL base do servidor GitLab (obrigatório para git_triggers)
GIT_BASE_URL=https://seu-gitlab-server
# Token pessoal para autenticação GitLab (obrigatório para git_triggers)
GIT_TOKEN=seu-token-aqui

# === Optional ===
# Caminho padrão para o CSV de testes
# CSV_DEFAULT_PATH=./test_steps.csv
# Ativar logs de debug (true/false)
# DEBUG=false
# Desabilitar verificação TLS (0 para desabilitar, 1 para habilitar)
# NODE_TLS_REJECT_UNAUTHORIZED=0
