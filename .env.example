# ═══════════════════════════════════════════════════════════════
# QA Tools — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════
#
# AUTO-GENERATED from shared/config-schema.ts. Do not edit manually.
# Run: npx tsx scripts/generate-env-example.ts

# ── Jira / Xray ──────────────────────────────────────────────
JIRA_BASE_URL=  # Jira base URL
JIRA_PERSONAL_TOKEN=  # Jira personal token (PAT para server, email:apiToken base64 para cloud)
JIRA_MODE=server  # Jira mode (server|cloud)
XRAY_BASE_URL=  # Xray base URL
XRAY_MODE=server  # Xray mode (server|cloud)
XRAY_CLIENT_ID=  # Xray client ID
XRAY_CLIENT_SECRET=  # Xray client secret
XRAY_CLOUD_URL=https://xray.cloud.getxray.app  # Xray cloud URL
JIRA_PROJECT=YOUR_PROJECT_KEY  # Jira project key

# ── Git (GitLab) ──────────────────────────────────────────────
GIT_TOKEN=  # Git token
GIT_BASE_URL=  # Git base URL

# ── Git (GitHub) ──────────────────────────────────────────────
GITHUB_TOKEN=  # GitHub token
GITHUB_API_URL=https://api.github.com  # GitHub API URL
GITHUB_PR_NUMBER=0  # GitHub PR number for comment posting

# ── Cypress ──────────────────────────────────────────────
CYPRESS_PROJECT_PATH=  # Cypress project path

# ── CSV / JSON Import ──────────────────────────────────────────────
CSV_DEFAULT_PATH=  # CSV default path
CSV_PATH=  # CSV path
CSV_LABELS=  # CSV labels
JSON_PATH=  # JSON path
JSON_LABELS=  # JSON labels

# ── Behavior ──────────────────────────────────────────────
AUTO_CHOICE=  # Auto choice
AUTO_CONFIRM=false  # Auto confirm mode
DRY_RUN=false  # Dry run mode
DEBUG=false  # Debug mode
QUIET=false  # Quiet mode
ON_ERROR=abort  # Error action (abort|skip|continue)
SKIP_FIRST_RUN=false  # Skip first-run wizard
NO_COLOR=false  # Disable ANSI color output (NO_COLOR standard)
QA_TOOLS_NO_CLEAR=false  # Disable console.clear() between screens

# ── QA Tools ──────────────────────────────────────────────
QA_TOOLS_LOGS_DIR=logs  # Log output directory
QA_TOOLS_TEMP_DIR=  # Temporary directory override
QA_TOOLS_REPORTS_DIR=  # Reports output directory
QA_AUTO_BUG=false  # Auto-create Jira bug on new failures
QA_FAIL_ON=80  # Quality gate: minimum pass rate
QA_PUBLISH=  # Report publish target (s3|gh-pages)
QA_MAPPING_PATH=  # Test-to-Jira mapping file path
BENCHMARK=false  # Enable LLM benchmark mode
QA_COST_PER_COMPUTE_MINUTE=0  # Pipeline compute cost per minute (USD)
AWS_S3_BUCKET=  # AWS S3 bucket for report publishing
QA_GATE_MIN_PASS_RATE=80  # Quality gate: minimum pass rate (%)
QA_GATE_MAX_FLAKY_PCT=30  # Quality gate: maximum flaky rate (%)
QA_GATE_MIN_COVERAGE=70  # Quality gate: minimum coverage (%)
QA_GATE_MAX_SUITE_SPEED=8  # Quality gate: maximum suite speed (s/test)
QA_GIT_BLAME_IGNORE=  # Git blame ignore revisions (space-separated hashes)
METRICS_MAX_RUNS=50  # Max metrics runs retained (prune oldest on save)
REPORT_CACHE_MAX=20  # Max cached CTRF reports retained (prune oldest on save)

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO  # Log level
LOG_FILE=false  # Log to file
LOG_DIR=logs  # Log directory
LOG_MAX_SIZE=5242880  # Max log file size

# ── State ──────────────────────────────────────────────
XDG_STATE_HOME=  # XDG state home

# ── LLM Providers ──────────────────────────────────────────────
LLM_API_KEY=  # LLM API key
LLM_MODEL=google/gemini-2.0-flash-exp  # LLM model
LLM_BASE_URL=https://openrouter.ai/api/v1  # LLM base URL
LLM_SMALL_API_KEY=  # LLM small API key
LLM_SMALL_MODEL=gemini-2.0-flash-lite  # LLM small model
LLM_FAST_API_KEY=  # LLM fast API key
LLM_FAST_MODEL=llama-3.1-8b-instant  # LLM fast model
LLM_FAST_BASE_URL=https://api.groq.com/openai/v1  # LLM fast base URL
LLM_REVIEW_API_KEY=  # LLM review API key
LLM_REVIEW_MODEL=gemini-2.0-flash-exp  # LLM review model
LLM_REVIEW_BASE_URL=https://generativelanguage.googleapis.com/v1beta  # LLM review base URL
LLM_FALLBACK_API_KEY=  # LLM fallback API key
LLM_FALLBACK_MODEL=meta/llama3-70b-instruct  # LLM fallback model
LLM_FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1  # LLM fallback base URL
LLM_BATCH_API_KEY=  # LLM batch API key (same as GITHUB_TOKEN)
LLM_BATCH_MODEL=gpt-4o-mini  # LLM batch model
LLM_BATCH_BASE_URL=https://models.inference.ai.azure.com  # LLM batch base URL
LLM_MAX_TOKENS_PER_OP=128000  # LLM max tokens per operation
LLM_MAX_TOTAL_TOKENS=0  # LLM max total tokens
KNOWN_ISSUES_PATH=  # Known issues JSON path
LLM_REVIEW_BUDGET=0.5  # Maximum USD per session for adversarial review
LLM_REVIEW_STRATEGY=selective  # Review strategy (selective|always)
LLM_RATE_LIMIT=10  # LLM rate limit (req/min per tier)
LLM_FETCH_RETRIES=3  # LLM fetch retries per provider
LLM_DISK_CACHE_DIR=  # LLM disk cache directory
LLM_CACHE_KEY=  # LLM cache key override

# ── CI/CD ──────────────────────────────────────────────
CI=  # CI/CD environment flag (set by CI systems)
GITHUB_REPOSITORY=  # GitHub repository (owner/repo)
CI_JOB_NAME=  # CI job name (GitLab)
GITHUB_WORKFLOW=  # GitHub Actions workflow name
CI_JOB_URL=  # CI job URL (GitLab)
GITHUB_SERVER_URL=  # GitHub server URL
CI_COMMIT_BRANCH=  # CI commit branch (GitLab)
GITHUB_REF_NAME=  # GitHub ref name
CI_JOB_TOKEN=  # CI job token (GitLab)
CI_PROJECT_ID=  # CI project ID (GitLab)
CI_SERVER_URL=  # CI server URL (GitLab)
CI_PR_NUMBER=  # CI PR/MR number (GitLab)

# ── Opencode ──────────────────────────────────────────────
OPENCODE_DB_TIMEOUT_MS=300000  # Timeout (ms) for opencode SQLite database maintenance CLI calls

