# ═══════════════════════════════════════════════════════════════
# QA Tools — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════
#
# Auto-generated from shared/config-schema.ts.
# This file is the source of truth — keep in sync with CONFIG_SCHEMA.

# ── Jira ──────────────────────────────────────────────────────
JIRA_BASE_URL=https://seu-site.atlassian.net
JIRA_MODE=server
JIRA_PERSONAL_TOKEN=
XRAY_BASE_URL=https://xray.cloud.getxray.app
XRAY_MODE=server
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
XRAY_CLOUD_URL=
JIRA_PROJECT=YOUR_PROJECT_KEY

# ── Git (GitLab) ──────────────────────────────────────────────
GIT_TOKEN=
GIT_BASE_URL=https://gitlab.seusite.com

# ── Git (GitHub) ──────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# ── Cypress ───────────────────────────────────────────────────
CYPRESS_PROJECT_PATH=

# ── CSV / JSON import ─────────────────────────────────────────
CSV_DEFAULT_PATH=
CSV_PATH=
CSV_LABELS=
JSON_PATH=
JSON_LABELS=

# ── Behavior ──────────────────────────────────────────────────
AUTO_CHOICE=
AUTO_CONFIRM=false
DRY_RUN=false
DEBUG=false
QUIET=false
ON_ERROR=abort

# ── Quality Gate Thresholds ───────────────────────────────────
QA_GATE_MIN_PASS_RATE=80
QA_GATE_MAX_FLAKY_PCT=30
QA_GATE_MIN_COVERAGE=70
QA_GATE_MAX_SUITE_SPEED=8

# ── Flaky Auto-Management ────────────────────────────────────
QA_FLAKY_THRESHOLD=30
QA_FLAKY_STABLE_THRESHOLD=5
QA_FLAKY_AUTO_ACTIONS=true

# ── Auto-Triage ───────────────────────────────────────────────
QA_AUTO_BUG=true
QA_GIT_BLAME_IGNORE=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=true
LOG_DIR=logs
LOG_MAX_SIZE=5242880

# ── State ─────────────────────────────────────────────────────
XDG_STATE_HOME=

# ═══════════════════════════════════════════════════════════════
# LLM Providers
# ═══════════════════════════════════════════════════════════════

# ── Main (OpenRouter) — análise principal, fallback chain ─────
# Fallback: NVIDIA NIM → GitHub Models. 3 retries cada.
# https://openrouter.ai
LLM_API_KEY=sk-or-v1-
LLM_MODEL=google/gemini-2.0-flash-exp
LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Small — tasks leves (alias para fast por enquanto) ─────────
LLM_SMALL_API_KEY=
LLM_SMALL_MODEL=gemini-2.0-flash-lite

# ── Fast (Groq) — PR descriptions, classify, run-comparison ───
# https://console.groq.com
LLM_FAST_API_KEY=gsk_
LLM_FAST_MODEL=llama-3.1-8b-instant
LLM_FAST_BASE_URL=https://api.groq.com/openai/v1

# ── Review Strategy ────────────────────────────────────────────
LLM_REVIEW_BUDGET=0.50
LLM_REVIEW_STRATEGY=selective

# ── Reviewer (Gemini Pro) — cross-validation de análises ──────
# https://aistudio.google.com
LLM_REVIEW_API_KEY=AIza
LLM_REVIEW_MODEL=gemini-2.0-flash-exp
LLM_REVIEW_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Fallback (NVIDIA NIM) — circuit breaker quando main falha ─
# https://build.nvidia.com
LLM_FALLBACK_API_KEY=nvapi-
LLM_FALLBACK_MODEL=meta/llama3-70b-instruct
LLM_FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Batch (GitHub Models) — background tasks ──────────────────
# GitHub token (classic) com permissão para models.
# https://github.com/marketplace/models
LLM_BATCH_API_KEY=ghp_
LLM_BATCH_MODEL=gpt-4o-mini
LLM_BATCH_BASE_URL=https://models.inference.ai.azure.com

# ── Cache & Limits ────────────────────────────────────────────
LLM_MAX_TOKENS_PER_OP=128000
LLM_MAX_TOTAL_TOKENS=0

# ── Known issues ──────────────────────────────────────────────
KNOWN_ISSUES_PATH=
