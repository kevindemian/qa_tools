#!/usr/bin/env sh
# Pre-push hook: --no-verify detection + CI checks + validation hook + security scan
set -e

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
AUDIT_LOG="$PROJECT_ROOT/.opencode/warden/audit.log"

# ─── Security: --no-verify detection ────────────────────────────────────
if [ "${GIT_PUSH_NO_VERIFY:-0}" = "1" ]; then
  TIMESTAMP=$(date -Iseconds)
  USER_NAME=$(git config user.name || echo "unknown")
  USER_EMAIL=$(git config user.email || echo "unknown")
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

  BYPASS_MARKER="$PROJECT_ROOT/.opencode/warden/.bypass-authorized"
  if [ -f "$BYPASS_MARKER" ]; then
    echo "[pre-push] Authorized bypass detected. Logging to $AUDIT_LOG"
    mkdir -p "$(dirname "$AUDIT_LOG")"
    echo "{\"timestamp\":\"$TIMESTAMP\",\"type\":\"bypass\",\"subtype\":\"push-no-verify\",\"user\":\"$USER_NAME <$USER_EMAIL>\",\"branch\":\"$BRANCH\",\"authorized\":true}" >> "$AUDIT_LOG"
    rm -f "$BYPASS_MARKER"
  else
    cat <<'BLOCK'
================================================================
  SECURITY: git push --no-verify detected (unauthorized)
================================================================
  Pushing with --no-verify bypasses all safety hooks.
  To authorize, create: touch .opencode/warden/.bypass-authorized
  See Rule 18 in AGENTS.md for the protocol.
================================================================
BLOCK
    mkdir -p "$(dirname "$AUDIT_LOG")"
    echo "{\"timestamp\":\"$TIMESTAMP\",\"type\":\"bypass\",\"subtype\":\"push-no-verify-blocked\",\"user\":\"$USER_NAME <$USER_EMAIL>\",\"branch\":\"$BRANCH\",\"authorized\":false}" >> "$AUDIT_LOG"
    exit 1
  fi
fi

# ─── CI Checks ──────────────────────────────────────────────────────────
echo "=== Pre-push checks ==="

echo "--- Typecheck ---"
npm run typecheck

echo "--- Quality enforcement ---"
npm run lint

# Dependency update check before push
if [ -f scripts/check-updates.sh ]; then
    echo "--- Dependency updates ---"
    bash scripts/check-updates.sh
fi

# Validation hook: self-test + staged diff check
VALIDATION_HOOK="$HOME/.config/opencode/validation_hook.ts"
if [ -f "$VALIDATION_HOOK" ]; then
  echo "--- Validation hook (self-test) ---"
  npx tsx "$VALIDATION_HOOK" --test

  echo "--- Validation hook (diff check) ---"
  DIFF=$(git diff --cached)
  if [ -n "$DIFF" ]; then
    echo "$DIFF" | grep -v '^-[^-]' | npx tsx "$VALIDATION_HOOK" --check
  else
    echo "  (no staged changes to check)"
  fi
fi

echo "--- Tests ---"
npm test

# Security log scan
if [ -x "$PROJECT_ROOT/scripts/scan-sec-logs.sh" ]; then
  echo "--- Security log scan ---"
  "$PROJECT_ROOT/scripts/scan-sec-logs.sh" --quiet
fi

echo "=== All pre-push checks passed ==="
