#!/usr/bin/env sh
# Pre-push hook: --no-verify detection + CI-equivalent checks.
#
# Optimization (no safety loss): if pre-commit left a fresh attestation marker
# recording the EXACT tree being pushed, the checks that pre-commit already ran
# on that same content (typecheck, validation, check-updates, full test suite)
# are skipped. Only the pre-push-unique gate (quality-check / unused-exports /
# handlers) and the security log scan run in normal flow.
#
# If no matching marker exists (commit was --no-verify'd, amended, or rebased),
# the FULL set runs as a backstop — every safety mechanism still executes.
set -e

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
AUDIT_LOG="$PROJECT_ROOT/.opencode/warden/audit.log"
GITDIR="$(git rev-parse --git-dir)"

# ─── Security: --no-verify detection ────────────────────────────────────
if [ "${GIT_PUSH_NO_VERIFY:-0}" = "1" ]; then
  TIMESTAMP=$(date -Iseconds)
  USER_NAME=$(git config user.name || echo "unknown")
  USER_EMAIL=$(git config user.email || echo "unknown")
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

  BYPASS_MARKER="$PROJECT_ROOT/.opencode/warden/.bypass-authorized"
  if [ -f "$BYPASS_MARKER" ]; then
    echo "[pre-push] Authorized bypass detected. Logging to $AUDIT_LOG"
    mkdir -p "$(dirname "$AUDIT_LOG")"
    echo "{\"timestamp\":\"$TIMESTAMP\",\"type\":\"bypass\",\"subtype\":\"push-no-verify\",\"user\":\"$USER_NAME <$USER_EMAIL>\",\"branch\":\"$BRANCH\",\"authorized\":true}" >> "$AUDIT_LOG"
    rm -f "$BYPASS_MARKER"
  else
    cat <<'BLOCK'
================================================================
  SECURITY: git push --no-verify detected (unauthorized)
================================================================
  Pushing with --no-verify bypasses all safety hooks.
  To authorize, create: touch .opencode/warden/.bypass-authorized
  See Rule 18 in AGENTS.md for the protocol.
================================================================
BLOCK
    mkdir -p "$(dirname "$AUDIT_LOG")"
    echo "{\"timestamp\":\"$TIMESTAMP\",\"type\":\"bypass\",\"subtype\":\"push-no-verify-blocked\",\"user\":\"$USER_NAME <$USER_EMAIL>\",\"branch\":\"$BRANCH\",\"authorized\":false}" >> "$AUDIT_LOG"
    exit 1
  fi
fi

echo "=== Pre-push checks ==="

# ---- Parallel runner (backstop path) --------------------------------------
PAR_LOGS="$(mktemp -d)"
PAR_LABELS=""

queue_job() {
    local label="$1"; shift
    PAR_LABELS="$PAR_LABELS $label"
    (
        "$@" > "$PAR_LOGS/$label.out" 2>&1
        echo "$?" > "$PAR_LOGS/$label.rc"
    ) &
}

run_parallel() {
    wait || true
    local fail=0
    for label in $PAR_LABELS; do
        local rc
        rc="$(cat "$PAR_LOGS/$label.rc" 2>/dev/null || echo 1)"
        if [ "$rc" != "0" ]; then
            echo "::error::pre-push check '$label' failed (rc=$rc)"
            echo "----- output -----"
            cat "$PAR_LOGS/$label.out" 2>/dev/null
            echo "------------------"
            fail=1
        fi
    done
    PAR_LABELS=""
    return $fail
}

MARKER="$GITDIR/validated-commit"
HEAD_TREE="$(git rev-parse HEAD^{tree})"

if [ -f "$MARKER" ] && [ "$(cat "$MARKER" 2>/dev/null)" = "$HEAD_TREE" ]; then
  echo "--- Reusing pre-commit attestation for tree $HEAD_TREE (skipping typecheck/validation/check-updates/tests) ---"

  # Unique pre-push gate: unused-exports / handlers enforcement.
  echo "--- Quality enforcement ---"
  npm run lint

  # Security log scan.
  if [ -x "$PROJECT_ROOT/scripts/scan-sec-logs.sh" ]; then
    echo "--- Security log scan ---"
    "$PROJECT_ROOT/scripts/scan-sec-logs.sh" --quiet
  fi
else
  echo "--- No fresh attestation (commit bypassed/amended/rebased); running full backstop ---"

  # Typecheck (duplicate of pre-commit, kept as backstop)
  echo "--- Typecheck ---"
  queue_job "typecheck" npm run typecheck

  # Quality enforcement (unused-exports / handlers)
  echo "--- Quality enforcement ---"
  queue_job "quality" npm run lint

  # Dependency update check (informational)
  if [ -f scripts/check-updates.sh ]; then
    echo "--- Dependency updates ---"
    queue_job "check-updates" bash scripts/check-updates.sh
  fi

  # Validation hook: self-test + staged diff check
  VALIDATION_HOOK="$HOME/.config/opencode/validation_hook.ts"
  if [ -f "$VALIDATION_HOOK" ]; then
    echo "--- Validation hook ---"
    queue_job "validation" sh -c '
      npx tsx "$HOME/.config/opencode/validation_hook.ts" --test
      DIFF=$(git diff --cached)
      if [ -n "$DIFF" ]; then
        printf "%s\n" "$DIFF" | grep -v "^-[^-]" | npx tsx "$HOME/.config/opencode/validation_hook.ts" --check
      fi
    '
  fi

  # Full test suite (duplicate of CI; backstop only)
  echo "--- Tests ---"
  queue_job "tests" npm test

  # Security log scan
  if [ -x "$PROJECT_ROOT/scripts/scan-sec-logs.sh" ]; then
    echo "--- Security log scan ---"
    queue_job "sec-log-scan" "$PROJECT_ROOT/scripts/scan-sec-logs.sh" --quiet
  fi

  run_parallel || exit 1
fi

echo "=== All pre-push checks passed ==="
