{
    "name": "simple-login",
    "description": "User story for login functionality",
    "input": {
        "story": "As a registered user, I want to log in with my email and password so that I can access my dashboard.",
        "criteria": [
            "Login succeeds with valid credentials",
            "Login fails with wrong password",
            "Login fails with unregistered email",
            "Login button disabled while submitting"
        ]
