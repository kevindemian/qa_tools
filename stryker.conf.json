{
    "$schema": "https://stryker-mutator.io/stryker-configuration-schema.json",
    "packageManager": "npm",
    "reporters": ["html", "clear-text", "progress"],
    "testRunner": "vitest",
    "vitest": {
        "configFile": "vitest.config.stryker.ts",
        "related": false
    },
    "checkers": ["typescript"],
    "tsconfigFile": "tsconfig.json",
    "coverageAnalysis": "all",
    "thresholds": {
        "break": 50
    },
    "mutate": [
        "shared/**/*.ts",
        "!shared/**/*.test.ts",
        "!shared/**/*.spec.ts",
        "jira_management/**/*.ts",
        "!jira_management/**/*.test.ts",
        "!jira_management/**/*.spec.ts",
        "git_triggers/**/*.ts",
        "!git_triggers/**/*.test.ts",
        "!git_triggers/**/*.spec.ts",
        "scripts/**/*.ts",
        "!scripts/**/*.test.ts",
        "!scripts/**/*.spec.ts"
    ],
    "ignorePatterns": [
        "**/node_modules/**",
        "**/dist/**",
        "scripts/eslint-plugins/**",
        "scripts/run-mutation.ts",
        "scripts/audit-suppressions.ts"
    ]
}
